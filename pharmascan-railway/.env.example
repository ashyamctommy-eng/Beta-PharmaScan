# Copy this to .env and fill in your values
# Railway will inject PORT automatically - do NOT set it here

# Required: Groq API key (get free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override default SQLite DB path
# DATABASE_URL=sqlite+aiosqlite:///./pharmascan.db

# Optional: enable debug logging
DEBUG=false
